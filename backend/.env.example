DATABASE_URL=postgresql://clinic:43318.62Ka3@localhost:5432/clinic
MONGO_URI=mongodb://localhost:27017/clinic
REDIS_URL=redis://localhost:6379
# DATABASE_URL="postgresql://postgres:43318.62Ka3@localhost:5432/clinic_db?schema=public"

# eSMS (SMS provider)
# Đặt false khi dev/test để không tốn tiền SMS. Bật true khi deploy production.
ENABLE_REAL_SMS=false
ESMS_API_KEY=
ESMS_SECRET_KEY=
ESMS_API_URL=http://rest.esms.vn/MainService.svc/json/SendMultipleMessage_V4_get
# Tuỳ chọn
ESMS_SMS_TYPE=4
ESMS_BRANDNAME=

# Firebase (đăng nhập OTP qua số điện thoại)
# 1. Vào Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
# 2. Lưu file JSON vào backend (vd: firebase-service-account.json)
# 3. Thêm vào .gitignore
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
